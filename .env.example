APP_NAME=Migration FastAPI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_RATE_LIMIT_WINDOW_MINUTES=15
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=3
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_MINUTES=15
EMAIL_VERIFICATION_RATE_LIMIT_MAX_REQUESTS=3
FRONTEND_BASE_URL=http://localhost:3000
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Migration FastAPI
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
VEHICLES_LEGACY_UNBOUNDED=true
VEHICLE_PRICING_LEGACY_UNBOUNDED=true
ORDERS_LEGACY_UNBOUNDED=true
ADMIN_ORDERS_LEGACY_UNBOUNDED=false
CUSTOMERS_LEGACY_UNBOUNDED=false
CONTACT_RECIPIENT_EMAIL=support@example.com
CONTACT_AUTO_REPLY_ENABLED=true
QUOTE_LEAD_NOTIFICATION_EMAIL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=blog-thumbnails
ENABLE_DEV_STARTUP_DB_CHECK=true
DEV_STARTUP_REQUIRE_ALEMBIC_VERSION=true
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DISPLAY_NAME=Admin
SEED_ADMIN_MARK_EMAIL_VERIFIED=true
